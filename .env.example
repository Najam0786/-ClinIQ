# ── ClinIQ Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it's already in .gitignore).

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql://cliniq_user:your_password@localhost:5432/cliniq_db

# SQLite (local dev — no Postgres needed, auto-created as cliniq.db)
# DATABASE_URL=sqlite:///./cliniq.db

# ── JWT Authentication ─────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-random-64-char-string-in-production
ACCESS_TOKEN_TTL_MINUTES=480   # 8 hours

# ── MLflow ────────────────────────────────────────────────────────────────────
CLINIQ_MLFLOW_ENABLED=true
MLFLOW_TRACKING_URI=mlruns
CLINIQ_MLFLOW_EXPERIMENT=ClinIQ-Production

# ── Data Drift ────────────────────────────────────────────────────────────────
CLINIQ_DRIFT_DIR=drift_reports          # directory for baselines + reports

# ── Rate Limiting ──────────────────────────────────────────────────────────────
# Default global limit. Login: 5/minute, Register: 10/minute (hardcoded).
CLINIQ_RATE_LIMIT=60/minute

# ── PostgreSQL container credentials (used by docker-compose) ─────────────────
POSTGRES_USER=cliniq_user
POSTGRES_PASSWORD=cliniq_secure_password
POSTGRES_DB=cliniq_db
